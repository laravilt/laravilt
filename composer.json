{
    "name": "laravilt/laravilt",
    "description": "Complete full-stack framework for building admin panels, frontend applications, and mobile apps from a single PHP Resource definition",
    "keywords": ["laravel", "admin", "panel", "vue", "flutter", "inertia", "full-stack", "filament"],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Fady Mondy",
            "email": "fadymondy@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "laravel/framework": "^12.0",
        "laravel/sanctum": "^4.2",
        "laravilt/support": "*",
        "laravilt/core": "*",
        "laravilt/forms": "*",
        "laravilt/tables": "*",
        "laravilt/grids": "*",
        "laravilt/actions": "*",
        "laravilt/infolists": "*",
        "laravilt/notifications": "*",
        "laravilt/widgets": "*",
        "laravilt/query-builder": "*",
        "laravilt/panel": "*"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^4.0",
        "larastan/larastan": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Laravilt\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Laravilt\\Tests\\": "tests/php/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Laravilt\\LaraviltServiceProvider"
            ]
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../support"
        },
        {
            "type": "path",
            "url": "../core"
        },
        {
            "type": "path",
            "url": "../ui"
        },
        {
            "type": "path",
            "url": "../forms"
        },
        {
            "type": "path",
            "url": "../tables"
        },
        {
            "type": "path",
            "url": "../grids"
        },
        {
            "type": "path",
            "url": "../actions"
        },
        {
            "type": "path",
            "url": "../infolists"
        },
        {
            "type": "path",
            "url": "../notifications"
        },
        {
            "type": "path",
            "url": "../widgets"
        },
        {
            "type": "path",
            "url": "../query-builder"
        },
        {
            "type": "path",
            "url": "../panel"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
